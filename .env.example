# Backend selection (the swap is here, not in code)
HARNESS_LLM_BACKEND=fake          # fake | openai_compatible | azure
HARNESS_MEMORY_BACKEND=in_memory  # in_memory | pgvector (pgvector lands in a later phase)
HARNESS_TOOL_PARSER=native        # native | prompted

# OpenAI-compatible local server (llama.cpp llama-server / vLLM / any compatible endpoint)
HARNESS_LLM_BASE_URL=http://localhost:8080/v1
HARNESS_LLM_MODEL=gemma4:a2b
HARNESS_LLM_API_KEY=              # leave blank; most local servers ignore it

# Azure OpenAI (cloud backend)
HARNESS_AZURE_ENDPOINT=https://your-resource.openai.azure.com
HARNESS_AZURE_DEPLOYMENT=gpt-5.4-mini
HARNESS_AZURE_API_VERSION=2024-10-21
HARNESS_AZURE_API_KEY=            # leave blank to use managed identity

# pgvector long-term memory (Postgres DSN; may equal the checkpointer DSN).
# Leave blank until the pgvector backend is wired (Phase 5).
HARNESS_MEMORY_URL=

HARNESS_MAX_ITERATIONS=8

{
  "version": "1.0",
  "description": "Tool-use golden cases. Manually reviewed. Expand before trusting any model on new tools.",
  "cases": [
    {
      "id": "calc_mul_001",
      "description": "Agent should use calculator for simple multiplication",
      "tags": ["calculator", "arithmetic", "op-variety", "smoke"],
      "input": "what is 12 * 9?",
      "expected": {
        "tool_call": { "name": "calculator" },
        "tool_args": { "expression": null },
        "output_contains": ["108"]
      }
    },
    {
      "id": "calc_add_001",
      "description": "Agent should use calculator for addition",
      "tags": ["calculator", "arithmetic", "op-variety"],
      "input": "what is 47 + 83?",
      "expected": {
        "tool_call": { "name": "calculator" },
        "tool_args": { "expression": null },
        "output_contains": ["130"]
      }
    },
    {
      "id": "calc_sub_001",
      "description": "Agent should use calculator for subtraction",

      "expected": {
        "tool_call": { "name": "recall" },
        "tool_args": { "query": null },
        "output_contains": ["Python"]
      }
    },
    {
      "id": "recall_project_001",
      "description": "Agent should recall context about an ongoing project",
      "tags": ["recall", "memory"],
      "input": "what project are we currently working on?",
      "memory_seed": ["The current project we are working on is agent-harness"],
      "expected": {
        "tool_call": { "name": "recall" },
        "tool_args": { "query": null },
        "output_contains": ["agent-harness"]
      }
    },
    {
      "id": "recall_job_001",
      "description": "Agent should recall the user's job title from memory",
      "tags": ["recall", "memory"],
      "input": "what is my job title?",
      "memory_seed": ["The user's job title is Senior Software Engineer"],
      "expected": {
        "tool_call": { "name": "recall" },
        "tool_args": { "query": null },
        "output_contains": ["Senior Software Engineer"]
      }
    },
    {
      "id": "direct_001",
      "description": "Agent should answer directly without a tool",
      "tags": ["direct"],
      "input": "say hello",
      "expected": {
        "no_tool_call": true,
        "output_contains": ["hello"]
      }
    },
    {
      "id": "direct_capital_001",
      "description": "Agent should answer world-knowledge question directly, no tool",
      "tags": ["direct"],

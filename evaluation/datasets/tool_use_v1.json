    {
      "id": "calc_neg_001",
      "description": "Agent should handle negative numbers",
      "tags": ["calculator", "arithmetic", "edge-case"],
      "input": "what is negative 8 times 7?",
      "expected": {
        "tool_call": { "name": "calculator" },
        "tool_args": { "expression": null },
        "output_contains": ["-56"]
      }
    },
    {
      "id": "calc_decimal_001",
      "description": "Agent should handle decimal inputs",
      "tags": ["calculator", "arithmetic", "edge-case"],
      "input": "what is 2.5 times 4?",
      "expected": {
        "tool_call": { "name": "calculator" },
        "tool_args": { "expression": null },
        "output_contains": ["10"]
      }
    },
    {
      "id": "calc_large_001",
      "description": "Agent should handle large number results",
      "tags": ["calculator", "arithmetic", "edge-case"],

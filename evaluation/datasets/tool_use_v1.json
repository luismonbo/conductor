    },
    {
      "id": "recall_001",
      "description": "Agent should use recall to look up stored user facts",
      "tags": ["recall", "memory"],
      "input": "where am I based?",
      "memory_seed": ["The user is based in San Francisco"],
      "expected": {
        "tool_call": { "name": "recall" },
        "tool_args": { "query": null },
        "output_contains": ["San Francisco"]
      }
    },
    {
      "id": "recall_name_001",
      "description": "Agent should recall the user's name from memory",
      "tags": ["recall", "memory"],
      "input": "what's my name?",
      "memory_seed": ["The user's name is Alex"],
      "expected": {
        "tool_call": { "name": "recall" },
        "tool_args": { "query": null },
        "output_contains": ["Alex"]
      }
    },
    {
      "id": "recall_pref_001",
